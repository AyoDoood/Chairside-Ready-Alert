<?xml version="1.0" encoding="utf-8"?>
<!--
    Chairside Ready Alert — MSIX manifest template.

    Three placeholders MUST be replaced with values from Partner Center
    BEFORE the package is uploaded for Store submission. They are
    bound cryptographically to your Partner Center app reservation —
    you cannot make them up.

      Apps and games -> Chairside Ready Alert -> Product management ->
                                                 App identity (or "Product Identity")

    The three values to copy (search-and-replace each TODO_* string below
    with the matching Partner Center value):

      1. TODO_PACKAGE_IDENTITY_NAME   in the <Identity Name="..."> attribute
         Partner Center calls this:    Package/Identity/Name
         Example shape:                12345FieldcrestDentalPC.ChairsideReadyAlert

      2. TODO_PUBLISHER                in the <Identity Publisher="..."> attribute
         Partner Center calls this:    Package/Identity/Publisher
         Example shape:                CN=A1B2C3D4-E5F6-7890-ABCD-EF1234567890

      3. TODO_PUBLISHER_DISPLAY_NAME   in the <PublisherDisplayName>...</PublisherDisplayName> element
         Partner Center calls this:    Package/Properties/PublisherDisplayName
         Example shape:                Fieldcrest Dental PC

    Two placeholders are filled in automatically by the GitHub Actions
    build at packaging time and should NOT be edited:

      VERSION_PLACEHOLDER : substituted from version.json + ".0"  (MSIX requires 4 segments)
      ARCH_PLACEHOLDER    : substituted with x64 / x86 / arm64 per matrix job
-->
<Package
    xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
    xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
    xmlns:desktop2="http://schemas.microsoft.com/appx/manifest/desktop/windows10/2"
    xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
    IgnorableNamespaces="uap desktop2 rescap">

  <Identity
    Name="FieldcrestDental.ChairsideReadyAlert"
    Publisher="CN=EBB36BC6-0F33-43EE-9493-D7B3C13F675C"
    Version="VERSION_PLACEHOLDER"
    ProcessorArchitecture="ARCH_PLACEHOLDER" />

  <Properties>
    <DisplayName>Chairside Ready Alert</DisplayName>
    <PublisherDisplayName>Fieldcrest Dental PC</PublisherDisplayName>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-us" />
  </Resources>

  <Applications>
    <Application Id="App"
                 Executable="ChairsideReadyAlert.exe"
                 EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
          DisplayName="Chairside Ready Alert"
          Description="LAN-based alert and messaging tool for dental practices."
          BackgroundColor="transparent"
          Square150x150Logo="Assets\Square150x150Logo.png"
          Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
            Wide310x150Logo="Assets\Wide310x150Logo.png"
            Square71x71Logo="Assets\Square71x71Logo.png"
            Square310x310Logo="Assets\Square310x310Logo.png" />
      </uap:VisualElements>
      <Extensions>
        <!--
            Explicit firewall rules. The privateNetworkClientServer capability
            below asks Windows to create reasonable inbound rules, but those
            auto-created rules can land disabled-on-Private (most common cause:
            a "Windows Defender Firewall — Allow this app?" prompt where the
            user dismissed or unchecked Private). Declaring rules here makes
            them deterministic — they are created enabled on every install
            and upgrade, with the exact protocols/ports/profiles below.
            Requires Windows 10 May 2020 update (build 19041) or later;
            ignored on older Windows, which falls back to the capability-only
            behavior.
            UDP 50506 = DISCOVERY_PORT (peer beacons).
            TCP 50505 = DEFAULT_PORT  (alert messages).
        -->
        <desktop2:Extension Category="windows.firewallRules">
          <desktop2:FirewallRules Executable="ChairsideReadyAlert.exe">
            <desktop2:Rule Direction="in"  IPProtocol="UDP" LocalPortMin="50506" LocalPortMax="50506" Profile="all"/>
            <desktop2:Rule Direction="in"  IPProtocol="TCP" LocalPortMin="50505" LocalPortMax="50505" Profile="all"/>
            <desktop2:Rule Direction="out" IPProtocol="UDP" LocalPortMin="50506" LocalPortMax="50506" Profile="all"/>
            <desktop2:Rule Direction="out" IPProtocol="TCP" LocalPortMin="50505" LocalPortMax="50505" Profile="all"/>
          </desktop2:FirewallRules>
        </desktop2:Extension>
      </Extensions>
    </Application>
  </Applications>

  <Capabilities>
    <!-- runFullTrust — required for desktop-bridge / PyInstaller-bundled apps.
         Auto-approved for personal Microsoft Store accounts on submission. -->
    <rescap:Capability Name="runFullTrust" />
    <!-- privateNetworkClientServer — LAN broadcast (UDP 50506) and TCP (50505)
         for peer discovery and alert messages. No internet capability declared
         because the Store build makes no outbound internet calls. -->
    <Capability Name="privateNetworkClientServer" />
  </Capabilities>
</Package>
